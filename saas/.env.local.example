# Copy this file to .env.local and fill in values

# PostgreSQL — Neon recommended (free, serverless-friendly)
# Neon gives two URLs: pooled (for app) and direct (for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-secret"

# NextAuth URL
NEXTAUTH_URL="https://your-app.vercel.app"
