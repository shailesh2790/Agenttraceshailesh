{
  "name": "agentrace",
  "version": "0.2.0",
  "description": "Validate and emit AgentTrace files — the open standard for recording what AI agents do",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "schemas"],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit"
