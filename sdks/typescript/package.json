  "keywords": ["agents", "llm", "observability", "tracing", "ai", "agentrace"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shailesh2790/Agenttraceshailesh.git"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
